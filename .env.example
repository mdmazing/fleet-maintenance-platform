# Copy this file to .env and fill in values for your environment.
# .env is git-ignored and must never be committed.

# PostgreSQL credentials (must match docker-compose.yml)
DB_USERNAME=fleet
DB_PASSWORD=fleet

# Override the JDBC URL when running the full Docker Compose stack
# (the app service connects to the internal Docker network, not localhost)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fleet_maintenance
